# Django
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=auth0_db
DB_USER=auth0_user
DB_PASSWORD=auth0_password
DB_HOST=db
DB_PORT=5432

# Auth0 - OAuth Application (Regular Web App)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_regular_web_app_client_id
AUTH0_CLIENT_SECRET=your_regular_web_app_client_secret

# Auth0 - Management API (M2M Application)
AUTH0_MANAGEMENT_CLIENT_ID=your_m2m_client_id
AUTH0_MANAGEMENT_CLIENT_SECRET=your_m2m_client_secret

# Django settings
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
